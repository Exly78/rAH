-- ===== HELPER FUNCTIONS =====

-- Returns the stat definition table
function StatData:GetStat(statName)
	return self.Stats[statName]
end

-- Returns all stat names as an ordered list
function StatData:GetAllStatNames()
	return { "Strength", "Agility", "Endurance", "Dexterity", "Intelligence", "Faith" }
end

-- Calculates derived combat values from a stats table
-- stats = { Strength = N, Agility = N, ... }
function StatData:CalculateDerived(stats)
	local derived = {
		BonusDamage       = 0,
		MaxHealthBonus    = 0,
		PostureBonus      = 0,
		DamageResistance  = 0,
		DodgeSpeedBonus   = 0,
		CritChance        = 0,
		VeilDamageBonus   = 0,
		SanityResistance  = 0,
	}

	local str = stats.Strength   or 0
	local agi = stats.Agility    or 0
	local endur = stats.Endurance  or 0
	local dex = stats.Dexterity  or 0
	local int = stats.Intelligence or 0
	local fai = stats.Faith      or 0

	derived.BonusDamage      = str * self.Stats.Strength.Effects.BaseDamageBonus
	derived.MaxHealthBonus   = endur * self.Stats.Endurance.Effects.MaxHealthBonus
	derived.PostureBonus     = endur * self.Stats.Endurance.Effects.PostureBonus
	derived.DamageResistance = math.min(0.4, endur * self.Stats.Endurance.Effects.DamageResistance)
	derived.DodgeSpeedBonus  = agi * self.Stats.Agility.Effects.DodgeSpeedBonus
	derived.CritChance       = agi * self.Stats.Agility.Effects.CritChanceBonus
	derived.VeilDamageBonus  = int * self.Stats.Intelligence.Effects.VeilDamageBonus
	derived.SanityResistance = fai * self.Stats.Faith.Effects.SanityResistance

	return derived
end

-- Checks whether a player's stats meet a weapon's requirements
-- stats = { Strength = N, ... }, weaponType = "Light"/"Medium"/"Heavy"/"Hybrid"/"Ranged"
function StatData:CanEquipWeaponType(stats, weaponType)
	for statName, statDef in pairs(self.Stats) do
		local req = statDef.WeaponRequirements[weaponType]
		if req and req > 0 then
			if (stats[statName] or 0) < req then
				return false, statName, req
			end
		end
	end
	return true
end

-- Returns the total points spent from a stats table
function StatData:TotalPointsSpent(stats)
	local total = 0
	for _, statName in ipairs(self:GetAllStatNames()) do
		total = total + (stats[statName] or 0)
	end
	return total
end

return StatData
